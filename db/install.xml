<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/stackmatheditor/db"
       VERSION="20260324"
       COMMENT="local_stackmatheditor tables">
  <TABLES>
    <TABLE NAME="local_stackmatheditor"
           COMMENT="Per-quiz per-question MathQuill toolbar configuration">
      <FIELDS>
        <FIELD NAME="id"                  TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="cmid"                TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0" SEQUENCE="false"
               COMMENT="Course module ID of the quiz (0 = global/legacy)"/>
        <FIELD NAME="questionbankentryid" TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0" SEQUENCE="false"
               COMMENT="Version-independent question bank entry ID"/>
        <FIELD NAME="allowed_elements"    TYPE="text"             NOTNULL="false" SEQUENCE="false"
               COMMENT="JSON object with allowed toolbar categories"/>
        <FIELD NAME="usermodified"        TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timecreated"         TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified"        TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="cmid_qbeid_ix" UNIQUE="false" FIELDS="cmid,questionbankentryid"
               COMMENT="Lookup by quiz + question bank entry"/>

      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
